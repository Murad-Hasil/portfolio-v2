# ── Database ──────────────────────────────────────────────────────────────────
# Neon pooled URL for application queries
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Neon direct URL for Alembic migrations (required by Neon)
DATABASE_DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Qdrant (Vector DB) ────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: groq | openai
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Uncomment to switch to OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# ── Embedding Provider ────────────────────────────────────────────────────────
# Options: fastembed | openai
# NOTE: Switching providers requires re-running scripts/seed-rag.py
#       because vector dimensions differ (fastembed=384, openai=1536)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Uncomment to switch to OpenAI embeddings
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
